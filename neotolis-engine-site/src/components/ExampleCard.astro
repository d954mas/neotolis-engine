---
import PlaceholderCover from './PlaceholderCover.astro';

interface SizeEntry {
  raw: number;
  gzip: number;
}

interface SizeData {
  engine: SizeEntry;
  resources: SizeEntry;
  total: { gzip: number };
  files: Record<string, SizeEntry>;
}

interface Props {
  slug: string;
  title: string;
  hasCover: boolean;
  sizeData?: SizeData | null;
}

const { slug, title, hasCover, sizeData } = Astro.props;

function formatSize(bytes: number): string {
  if (bytes >= 1048576) {
    return `${(bytes / 1048576).toFixed(3)} MB`;
  }
  if (bytes >= 1024) {
    return `${(bytes / 1024).toFixed(3)} KB`;
  }
  return `${bytes} B`;
}

const engineFiles = sizeData
  ? Object.entries(sizeData.files).filter(([f]) => !f.startsWith('assets/'))
  : [];
const resourceFiles = sizeData
  ? Object.entries(sizeData.files).filter(([f]) => f.startsWith('assets/'))
  : [];
---
<a href={`/examples/${slug}/`} class="block bg-bg-card rounded-lg overflow-hidden hover:ring-1 hover:ring-accent transition group">
  {hasCover ? (
    <img
      src={`/examples/${slug}/cover.png`}
      alt={title}
      class="aspect-video w-full object-cover"
    />
  ) : (
    <PlaceholderCover title={title} />
  )}

  <div class="p-4">
    <h3 class="font-bold text-text-primary group-hover:text-accent transition">{title}</h3>

    {sizeData ? (
      <div class="mt-2">
        <div class="flex items-baseline gap-2 flex-wrap">
          <span class="text-sm font-semibold text-accent">{formatSize(sizeData.engine?.gzip ?? sizeData.total.gzip)} engine</span>
          {sizeData.resources?.raw > 0 && (
            <span class="text-sm text-text-secondary">+ {formatSize(sizeData.resources.gzip)} resources</span>
          )}
        </div>
        <details class="mt-2">
          <summary class="text-sm text-text-secondary cursor-pointer hover:text-text-primary">
            Size breakdown
          </summary>
          <div class="mt-1 text-xs text-text-secondary space-y-0.5">
            {engineFiles.map(([filename, sizes]) => (
              <div class="flex justify-between">
                <span>{filename}</span>
                <span>{formatSize(sizes.gzip)}</span>
              </div>
            ))}
            <div class="flex justify-between font-semibold border-t border-border pt-1 mt-1">
              <span>Engine</span>
              <span>{formatSize(sizeData.engine?.gzip ?? sizeData.total.gzip)}</span>
            </div>
            {resourceFiles.length > 0 && (
              <>
                <div class="pt-1"></div>
                {resourceFiles.map(([filename, sizes]) => (
                  <div class="flex justify-between">
                    <span>{filename}</span>
                    <span>{formatSize(sizes.gzip)}</span>
                  </div>
                ))}
                <div class="flex justify-between font-semibold border-t border-border pt-1 mt-1">
                  <span>Resources</span>
                  <span>{formatSize(sizeData.resources.gzip)}</span>
                </div>
              </>
            )}
            <div class="flex justify-between font-semibold border-t border-border pt-1 mt-1">
              <span>Total</span>
              <span>{formatSize(sizeData.total.gzip)}</span>
            </div>
          </div>
        </details>
      </div>
    ) : (
      <p class="mt-2 text-sm text-text-secondary">Size data unavailable</p>
    )}
  </div>
</a>
