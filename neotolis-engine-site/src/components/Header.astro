---
const base = import.meta.env.BASE_URL;
---
<header class="sticky top-0 z-50 bg-bg-primary/80 backdrop-blur border-b border-white/10">
  <nav class="max-w-5xl mx-auto px-4 h-14 flex items-center justify-between">
    <a href={base} class="text-lg font-bold text-text-primary hover:text-accent transition-colors">
      Neotolis Engine
    </a>
    <div class="flex items-center gap-6">
      <a href="#overview" class="text-sm text-text-secondary hover:text-text-primary transition-colors">Overview</a>
      <a href="#features" class="text-sm text-text-secondary hover:text-text-primary transition-colors">Features</a>
      <a href="#examples" class="text-sm text-text-secondary hover:text-text-primary transition-colors">Examples</a>
      <iframe
        src="https://ghbtns.com/github-btn.html?user=d954mas&repo=neotolis-engine&type=star&count=true&size=large"
        frameborder="0"
        scrolling="0"
        width="170"
        height="30"
        title="GitHub Stars"
        class="hidden sm:block"
      ></iframe>
    </div>
  </nav>
</header>
