---
const principles = [
  {
    title: 'Code-first',
    text: 'Game controls the main loop. The engine gives building blocks, not a pipeline.',
  },
  {
    title: 'Explicit over implicit',
    text: 'You see everything. No hidden behavior, no magic behind the scenes.',
  },
  {
    title: 'Keep it simple',
    text: 'Less code is better. Simplify further when possible.',
  },
  {
    title: 'Tiny size',
    text: 'Every byte counts. Binary size tracked on every PR.',
  },
  {
    title: 'Set of modules',
    text: 'Use only what you need.',
  },
  {
    title: 'Prebuilt assets',
    text: 'Source formats packed into binaries at build time. Runtime loads packs on demand, no parsers.',
  },
];
---
<section id="overview" class="py-16 sm:py-20 bg-bg-secondary">
  <div class="max-w-3xl mx-auto px-4">
    <h2 class="text-3xl font-bold text-text-primary mb-10">Philosophy</h2>
    <ul class="space-y-6">
      {principles.map((p) => (
        <li>
          <h3 class="text-lg font-semibold text-text-primary">{p.title}</h3>
          <p class="mt-1 text-text-secondary leading-relaxed">{p.text}</p>
        </li>
      ))}
    </ul>
  </div>
</section>
