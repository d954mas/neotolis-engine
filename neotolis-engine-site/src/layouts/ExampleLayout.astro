---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={`${title} - Neotolis Engine example`} />
  <title>{title} | Neotolis Engine</title>
</head>
<body class="bg-bg-primary text-text-primary h-screen flex flex-col m-0">
  <div class="flex-none bg-bg-secondary px-4 py-2 flex items-center gap-3" style="height: 40px;">
    <a href="/" class="text-text-secondary hover:text-text-primary transition text-sm">
      &larr; Back
    </a>
    <span class="font-semibold text-text-primary text-sm">{title}</span>
  </div>
  <div class="flex-1 min-h-0">
    <slot />
  </div>
</body>
</html>
