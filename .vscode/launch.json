            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "preLaunchTask": "Build native-release"
        },
        {
            "name": "Debug WASM textured_quad",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:8086/index.html",
            "webRoot": "${workspaceFolder}/build/examples/textured_quad/wasm-debug",
            "preLaunchTask": "Build & Serve textured_quad (debug)",
            "userDataDir": "${workspaceFolder}/.vscode/.chrome-profile"
        },
        {
            "name": "Run WASM textured_quad (release)",
            "type": "chrome",
