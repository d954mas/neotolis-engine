{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug WASM hello",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:8080/index.html",
            "webRoot": "${workspaceFolder}/build/examples/hello/wasm-debug",
            "preLaunchTask": "Build & Serve WASM (debug)",
            "userDataDir": "${workspaceFolder}/.vscode/.chrome-profile"
        },
        {
            "name": "Run WASM hello (release)",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:8081/index.html",
            "webRoot": "${workspaceFolder}/build/examples/hello/wasm-release",
            "preLaunchTask": "Build & Serve WASM (release)",
            "userDataDir": "${workspaceFolder}/.vscode/.chrome-profile"
        },
        {
            "name": "Debug WASM bench_shapes",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:8082/index.html",
            "webRoot": "${workspaceFolder}/build/examples/bench_shapes/wasm-debug",
            "preLaunchTask": "Build & Serve bench_shapes (debug)",
            "userDataDir": "${workspaceFolder}/.vscode/.chrome-profile"
        },
        {
            "name": "Run WASM bench_shapes (release)",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:8083/index.html",
            "webRoot": "${workspaceFolder}/build/examples/bench_shapes/wasm-release",
            "preLaunchTask": "Build & Serve bench_shapes (release)",
            "userDataDir": "${workspaceFolder}/.vscode/.chrome-profile"
        },
        {
            "name": "Debug WASM spinning_cube",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:8084/index.html",
            "webRoot": "${workspaceFolder}/build/examples/spinning_cube/wasm-debug",
            "preLaunchTask": "Build & Serve spinning_cube (debug)",
            "userDataDir": "${workspaceFolder}/.vscode/.chrome-profile"
        },
        {
            "name": "Run WASM spinning_cube (release)",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:8085/index.html",
            "webRoot": "${workspaceFolder}/build/examples/spinning_cube/wasm-release",
            "preLaunchTask": "Build & Serve spinning_cube (release)",
            "userDataDir": "${workspaceFolder}/.vscode/.chrome-profile"
        },
        {
            "name": "Debug Desktop hello",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/examples/hello/native-debug/hello.exe",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "preLaunchTask": "Build native-debug"
        },
        {
            "name": "Run Desktop hello (release)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/examples/hello/native-release/hello.exe",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "preLaunchTask": "Build native-release"
        },
        {
            "name": "Debug Desktop bench_shapes",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/examples/bench_shapes/native-debug/bench_shapes.exe",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "preLaunchTask": "Build native-debug"
        },
        {
            "name": "Run Desktop bench_shapes (release)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/examples/bench_shapes/native-release/bench_shapes.exe",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "preLaunchTask": "Build native-release"
        },
        {
            "name": "Debug Desktop spinning_cube",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/examples/spinning_cube/native-debug/spinning_cube.exe",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "preLaunchTask": "Build native-debug"
        },
        {
            "name": "Run Desktop spinning_cube (release)",
