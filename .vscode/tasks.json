{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Configure native-debug",
            "type": "cmake",
            "command": "configure",
            "preset": "native-debug",
            "problemMatcher": []
        },
        {
            "label": "Configure wasm-debug-paired",
            "type": "shell",
            "command": "emcmake cmake --preset wasm-debug-paired && emcmake cmake --preset wasm-debug-simd",
            "options": {
                "shell": {
                    "executable": "cmd.exe",
                    "args": ["/c"]
                }
            },
            "problemMatcher": []
        },
        {
            "label": "Configure wasm-release-paired",
            "type": "shell",
            "command": "emcmake cmake --preset wasm-release-paired && emcmake cmake --preset wasm-release-simd",
            "options": {
                "shell": {
                    "executable": "cmd.exe",
                    "args": ["/c"]
                }
            },
            "problemMatcher": []
        },
        {
            "label": "Build native-debug",
            "type": "cmake",
            "command": "build",
            "preset": "native-debug",
            "group": "build",
            "problemMatcher": "$gcc"
        },
        {
            "label": "Build native-release",
            "type": "cmake",
            "command": "build",
            "preset": "native-release",
            "group": "build",
            "problemMatcher": "$gcc"
        },
        {
            "label": "Build pack builders (release)",
            "type": "shell",
            "command": "cmake --build build/_cmake/native-release --target build_tq_packs build_sponza_packs build_text_packs",
            "group": "build",
            "problemMatcher": "$gcc"
        },
        {
            "label": "Build & run pack builders (release)",
            "type": "shell",
            "command": "cmake --build build/_cmake/native-release --target build_tq_packs build_sponza_packs && build\\examples\\textured_quad\\native-release\\build_tq_packs.exe build/examples/textured_quad && build\\examples\\sponza\\native-release\\build_sponza_packs.exe build/examples/sponza",
            "options": { "shell": { "executable": "cmd.exe", "args": ["/c"] } },
            "group": "build",
            "problemMatcher": "$gcc"
        },
        {
            "label": "Build & run TQ packs (debug)",
            "type": "shell",
            "command": "cmake --build build/_cmake/native-debug --target build_tq_packs && build\\examples\\textured_quad\\native-debug\\build_tq_packs.exe build/examples/textured_quad",
            "options": { "shell": { "executable": "cmd.exe", "args": ["/c"] } },
            "group": "build",
            "problemMatcher": "$gcc"
        },
        {
            "label": "Build & run Sponza packs (debug)",
            "type": "shell",
            "command": "cmake --build build/_cmake/native-debug --target build_sponza_packs && build\\examples\\sponza\\native-debug\\build_sponza_packs.exe build/examples/sponza",
            "options": { "shell": { "executable": "cmd.exe", "args": ["/c"] } },
            "group": "build",
            "problemMatcher": "$gcc"
        },
        {
            "label": "Build wasm-debug-paired (cmake)",
            "type": "cmake",
            "command": "build",
            "preset": "wasm-debug-paired",
            "problemMatcher": "$gcc"
        },
        {
            "label": "Build wasm-debug-simd (cmake)",
            "type": "cmake",
            "command": "build",
            "preset": "wasm-debug-simd",
            "problemMatcher": "$gcc"
        },
        {
            "label": "Package SIMD wasm (debug)",
            "type": "shell",
            "command": "bash scripts/package_all_simd.sh wasm-debug-paired wasm-debug-simd",
            "problemMatcher": []
        },
        {
            "label": "Build wasm-debug-paired",
            "dependsOn": [
                "Configure wasm-debug-paired",
                "Build wasm-debug-paired (cmake)",
                "Build wasm-debug-simd (cmake)",
                "Package SIMD wasm (debug)"
            ],
            "dependsOrder": "sequence",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "Build wasm-release-paired (cmake)",
            "type": "cmake",
            "command": "build",
            "preset": "wasm-release-paired",
            "problemMatcher": "$gcc"
        },
        {
            "label": "Build wasm-release-simd (cmake)",
            "type": "cmake",
            "command": "build",
            "preset": "wasm-release-simd",
            "problemMatcher": "$gcc"
        },
        {
            "label": "Package SIMD wasm (release)",
            "type": "shell",
            "command": "bash scripts/package_all_simd.sh wasm-release-paired wasm-release-simd",
            "problemMatcher": []
        },
        {
            "label": "Build wasm-release-paired",
            "dependsOn": [
                "Configure wasm-release-paired",
                "Build wasm-release-paired (cmake)",
                "Build wasm-release-simd (cmake)",
                "Package SIMD wasm (release)"
            ],
            "dependsOrder": "sequence",
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Run tests (native-debug)",
            "type": "cmake",
            "command": "test",
            "preset": "native-debug",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "Ensure server (debug :8080)",
            "type": "shell",
            "command": "curl -s -o nul http://localhost:8080 >nul 2>&1 && (echo Server already running on :8080) || (start /b python -m http.server 8080 -d \"${workspaceFolder}/build/examples/hello/wasm-debug-paired\" & timeout /t 1 >nul)",
            "options": {
                "shell": {
                    "executable": "cmd.exe",
                    "args": ["/c"]
                }
            },
            "problemMatcher": []
        },
        {
            "label": "Ensure server (release :8081)",
            "type": "shell",
            "command": "curl -s -o nul http://localhost:8081 >nul 2>&1 && (echo Server already running on :8081) || (start /b python -m http.server 8081 -d \"${workspaceFolder}/build/examples/hello/wasm-release-paired\" & timeout /t 1 >nul)",
            "options": {
                "shell": {
                    "executable": "cmd.exe",
                    "args": ["/c"]
                }
            },
            "problemMatcher": []
        },
        {
            "label": "Build & Serve WASM (debug)",
            "dependsOn": ["Build wasm-debug-paired", "Ensure server (debug :8080)"],
            "dependsOrder": "sequence",
            "problemMatcher": []
        },
        {
            "label": "Build & Serve WASM (release)",
            "dependsOn": ["Build wasm-release-paired", "Ensure server (release :8081)"],
            "dependsOrder": "sequence",
            "problemMatcher": []
        },
        {
            "label": "Ensure server bench_shapes (debug :8082)",
            "type": "shell",
            "command": "curl -s -o nul http://localhost:8082 >nul 2>&1 && (echo Server already running on :8082) || (start /b python -m http.server 8082 -d \"${workspaceFolder}/build/examples/bench_shapes/wasm-debug-paired\" & timeout /t 1 >nul)",
            "options": {
                "shell": {
                    "executable": "cmd.exe",
                    "args": ["/c"]
                }
            },
            "problemMatcher": []
        },
        {
            "label": "Ensure server bench_shapes (release :8083)",
            "type": "shell",
            "command": "curl -s -o nul http://localhost:8083 >nul 2>&1 && (echo Server already running on :8083) || (start /b python -m http.server 8083 -d \"${workspaceFolder}/build/examples/bench_shapes/wasm-release-paired\" & timeout /t 1 >nul)",
            "options": {
