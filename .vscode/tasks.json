            },
            "problemMatcher": []
        },
        {
            "label": "Build & Serve bench_shapes (debug)",
            "dependsOn": ["Build wasm-debug-paired", "Ensure server bench_shapes (debug :8082)"],
            "dependsOrder": "sequence",
            "problemMatcher": []
        },
        {
            "label": "Build & Serve bench_shapes (release)",
            "dependsOn": ["Build wasm-release-paired", "Ensure server bench_shapes (release :8083)"],
            "dependsOrder": "sequence",
            "problemMatcher": []
