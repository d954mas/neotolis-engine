            "dependsOn": ["Build wasm-release-paired", "Ensure server sponza (release :8089)"],
            "dependsOrder": "sequence",
            "problemMatcher": []
        },
        {
            "label": "Quick build native-debug (no -Werror)",
            "type": "shell",
            "command": "cmake -S . -B build/_cmake/native-debug -DNT_NO_WERROR=ON --preset native-debug && cmake --build build/_cmake/native-debug",
            "options": { "shell": { "executable": "cmd.exe", "args": ["/c"] } },
            "group": "build",
            "problemMatcher": "$gcc"
        },
        {
            "label": "Quick build native-release (no -Werror)",
            "type": "shell",
            "command": "cmake -S . -B build/_cmake/native-release -DNT_NO_WERROR=ON --preset native-release && cmake --build build/_cmake/native-release",
            "options": { "shell": { "executable": "cmd.exe", "args": ["/c"] } },
            "group": "build",
            "problemMatcher": "$gcc"
        },
        {
            "label": "Build & run text packs (debug)",
            "type": "shell",
            "command": "cmake --build build/_cmake/native-debug --target build_text_packs && build\\examples\\text\\native-debug\\build_text_packs.exe build/examples/text",
            "options": { "shell": { "executable": "cmd.exe", "args": ["/c"] } },
            "group": "build",
            "problemMatcher": "$gcc"
        }
    ]
}
