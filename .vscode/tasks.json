{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Configure native-debug",
            "type": "cmake",
            "command": "configure",
            "preset": "native-debug",
            "problemMatcher": []
        },
        {
            "label": "Configure wasm-debug",
            "type": "shell",
            "command": "emcmake",
            "args": ["cmake", "--preset", "wasm-debug"],
            "problemMatcher": []
        },
        {
            "label": "Build native-debug",
            "type": "cmake",
            "command": "build",
            "preset": "native-debug",
            "group": "build",
            "problemMatcher": "$gcc"
        },
        {
            "label": "Build native-release",
            "type": "cmake",
            "command": "build",
            "preset": "native-release",
            "group": "build",
            "problemMatcher": "$gcc"
        },
        {
            "label": "Build wasm-debug",
            "type": "cmake",
            "command": "build",
            "preset": "wasm-debug",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$gcc"
        },
        {
            "label": "Build wasm-release",
            "type": "cmake",
            "command": "build",
            "preset": "wasm-release",
            "group": "build",
            "problemMatcher": "$gcc"
        },
        {
            "label": "Run tests (native-debug)",
            "type": "cmake",
            "command": "test",
            "preset": "native-debug",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "Serve WASM debug (localhost:8080)",
            "type": "shell",
            "command": "python",
            "args": [
                "-m", "http.server", "8080",
                "-d", "${workspaceFolder}/build/examples/hello/wasm-debug"
            ],
            "isBackground": true,
            "problemMatcher": {
                "pattern": {
                    "regexp": "^never$"
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".",
                    "endsPattern": "Serving HTTP"
                }
            }
        },
        {
            "label": "Serve WASM release (localhost:8080)",
            "type": "shell",
            "command": "python",
            "args": [
                "-m", "http.server", "8080",
                "-d", "${workspaceFolder}/build/examples/hello/wasm-release"
            ],
            "isBackground": true,
            "problemMatcher": {
                "pattern": {
                    "regexp": "^never$"
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".",
                    "endsPattern": "Serving HTTP"
                }
            }
        },
        {
            "label": "Build & Serve WASM hello (debug)",
            "dependsOn": ["Build wasm-debug", "Serve WASM debug (localhost:8080)"],
            "dependsOrder": "sequence",
            "problemMatcher": []
        },
        {
            "label": "Build & Serve WASM hello (release)",
            "dependsOn": ["Build wasm-release", "Serve WASM release (localhost:8080)"],
            "dependsOrder": "sequence",
            "problemMatcher": []
        }
    ]
}
