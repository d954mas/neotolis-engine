            "type": "shell",
            "command": "curl -s -o nul http://localhost:8089 >nul 2>&1 && (echo Server already running on :8089) || (start /b python -m http.server 8089 -d \"${workspaceFolder}/build/examples/sponza/wasm-release-paired\" & timeout /t 1 >nul)",
            "options": {
